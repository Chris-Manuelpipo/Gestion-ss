<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox styleClass="modal-card" maxWidth="560" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.securitesociale.controller.ConsultationFormController">

    <HBox styleClass="modal-header" alignment="CENTER_LEFT">
        <StackPane styleClass="modal-header-icon">
            <FontIcon iconLiteral="fas-stethoscope" iconSize="22" styleClass="modal-header-fa-icon"/>
        </StackPane>
        <VBox styleClass="modal-header-text">
            <Label text="Nouvelle Consultation" styleClass="modal-header-title"/>
            <Label text="Remplissez les informations de la consultation" styleClass="modal-header-subtitle"/>
        </VBox>
    </HBox>

    <VBox styleClass="modal-body" minWidth="480" spacing="16">
        <VBox spacing="6">
            <Label text="Date de la consultation *" styleClass="field-label"/>
            <DatePicker fx:id="datePicker" promptText="jj/mm/aaaa"
                        styleClass="date-picker-modern" maxWidth="Infinity"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Patient *" styleClass="field-label"/>
            <ComboBox fx:id="assureCombo" promptText="Sélectionner un patient..."
                      styleClass="combo-box-modern" maxWidth="Infinity"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Motif *" styleClass="field-label"/>
            <TextField fx:id="motifField" promptText="Ex : Consultation de routine"
                       styleClass="text-field-modern"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Diagnostic" styleClass="field-label"/>
            <TextArea fx:id="diagnosticArea" promptText="Observations, diagnostic..."
                      styleClass="text-field-modern"
                      style="-fx-pref-height: 100px; -fx-padding: 10px 14px;"
                      wrapText="true"/>
        </VBox>

        <Label fx:id="errorLabel" text="" styleClass="error-label"
               visible="false" managed="false" wrapText="true"/>
    </VBox>

    <HBox styleClass="modal-footer">
        <Button text="Annuler" styleClass="btn-secondary" onAction="#handleCancel"/>
        <Button fx:id="saveBtn" text="✔ Enregistrer la consultation"
                styleClass="btn-primary" onAction="#handleSave"/>
    </HBox>

</VBox>
