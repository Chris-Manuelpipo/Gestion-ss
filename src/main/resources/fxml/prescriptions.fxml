<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane fitToWidth="true" styleClass="content-scroll"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.securitesociale.controller.PrescriptionsController">

    <VBox spacing="24">
        <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

        <!-- ── En-tête ── -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4">
                <Label text="Prescriptions"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                <Label text="Gérer les prescriptions médicales"
                       style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnNewPrescription" text="+ Nouvelle prescription"
                    styleClass="btn-primary" onAction="#handleNewPrescription"/>
        </HBox>

        <!-- ── Carte stat ── -->
        <HBox spacing="16">
            <VBox styleClass="stat-card, stat-card-green" spacing="8" HBox.hgrow="ALWAYS">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <FontIcon iconLiteral="fas-pills" iconSize="24" styleClass="stat-icon stat-icon-green"/>
                <Label fx:id="statTotal" text="—" styleClass="stat-number-green"/>
                <Label text="Prescriptions" styleClass="stat-label"/>
            </VBox>
        </HBox>

        <!-- ── Carte principale ── -->
        <VBox styleClass="card" spacing="0">

            <!-- Barre de recherche -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                <TextField fx:id="searchField"
                           promptText="Rechercher par type, contenu, patient..."
                           styleClass="search-field"
                           style="-fx-pref-width: 340px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="countLabel"
                       style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
            </HBox>

            <Separator/>

            <!-- TableView -->
            <TableView fx:id="tableView" styleClass="table-view"
                       style="-fx-border-width: 0; -fx-background-radius: 0;"
                       VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNum"          text="N°"        prefWidth="55"  minWidth="50"/>
                    <TableColumn fx:id="colDate"         text="Date"      prefWidth="110" minWidth="90"/>
                    <TableColumn fx:id="colType"         text="Type"      prefWidth="140" minWidth="110"/>
                    <TableColumn fx:id="colContenu"      text="Contenu"   prefWidth="250" minWidth="150"/>
                    <TableColumn fx:id="colConsultation" text="Cons. N°"  prefWidth="100" minWidth="80"/>
                    <TableColumn fx:id="colPatient"      text="Patient"   prefWidth="180" minWidth="130"/>
                    <TableColumn fx:id="colActions"      text="Actions"   prefWidth="100" minWidth="90"/>
                </columns>
                <placeholder>
                    <Label text="Aucune prescription trouvée"
                           style="-fx-text-fill: #94A3B8; -fx-font-size: 14px; -fx-padding: 40;"/>
                </placeholder>
            </TableView>

            <!-- Pagination -->
            <HBox alignment="CENTER" spacing="12">
                <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
                <Button fx:id="btnPrevPage" text="◀ Précédent"
                        styleClass="btn-secondary" onAction="#handlePrevPage"
                        style="-fx-pref-height: 36px; -fx-font-size: 12px;"/>
                <Label fx:id="pageInfoLabel"
                       style="-fx-font-size: 13px; -fx-text-fill: #64748B; -fx-min-width: 120px; -fx-alignment: CENTER;"/>
                <Button fx:id="btnNextPage" text="Suivant ▶"
                        styleClass="btn-secondary" onAction="#handleNextPage"
                        style="-fx-pref-height: 36px; -fx-font-size: 12px;"/>
            </HBox>

        </VBox>
    </VBox>
</ScrollPane>
