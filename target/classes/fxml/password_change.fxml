<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox styleClass="modal-card" maxWidth="480" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.securitesociale.controller.PasswordChangeController">

    <HBox styleClass="modal-header" alignment="CENTER_LEFT">
        <StackPane styleClass="modal-header-icon">
            <FontIcon iconLiteral="fas-lock" iconSize="22" styleClass="modal-header-fa-icon"/>
        </StackPane>
        <VBox styleClass="modal-header-text">
            <Label text="Changer le mot de passe" styleClass="modal-header-title"/>
            <Label text="Saisissez votre mot de passe actuel et un nouveau mot de passe"
                   styleClass="modal-header-subtitle"/>
        </VBox>
    </HBox>

    <VBox styleClass="modal-body" minWidth="400" spacing="16">
        <VBox spacing="6">
            <Label text="Mot de passe actuel *" styleClass="field-label"/>
            <PasswordField fx:id="currentField" promptText="Votre mot de passe actuel"
                           styleClass="text-field-modern"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Nouveau mot de passe *" styleClass="field-label"/>
            <PasswordField fx:id="newField" promptText="Minimum 8 caractères"
                           styleClass="text-field-modern"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Confirmer le nouveau mot de passe *" styleClass="field-label"/>
            <PasswordField fx:id="confirmField" promptText="Ressaisir le nouveau mot de passe"
                           styleClass="text-field-modern"/>
        </VBox>

        <Label fx:id="errorLabel" text="" styleClass="error-label"
               visible="false" managed="false" wrapText="true"/>
    </VBox>

    <HBox styleClass="modal-footer">
        <Button text="Annuler" styleClass="btn-secondary" onAction="#handleCancel"/>
        <Button fx:id="saveBtn" text="✔ Changer le mot de passe"
                styleClass="btn-primary" onAction="#handleSave"/>
    </HBox>

</VBox>
