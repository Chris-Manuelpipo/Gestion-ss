<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane fitToWidth="true" styleClass="content-scroll"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.securitesociale.controller.PatientsController">

    <VBox spacing="24">
        <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

        <!-- ── En-tête ── -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4">
                <Label text="Mes Patients"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                <Label text="Liste des patients sous votre suivi médical"
                       style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
            </VBox>
        </HBox>

        <!-- ── Carte stat ── -->
        <HBox spacing="16">
            <VBox styleClass="stat-card, stat-card-blue" spacing="8" HBox.hgrow="ALWAYS">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <FontIcon iconLiteral="fas-users" iconSize="24" styleClass="stat-icon stat-icon-blue"/>
                <Label fx:id="statTotal" text="—" styleClass="stat-number"/>
                <Label text="Patients" styleClass="stat-label"/>
            </VBox>
        </HBox>

        <!-- ── Carte principale ── -->
        <VBox styleClass="card" spacing="0">

            <!-- Barre de recherche -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
                <TextField fx:id="searchField"
                           promptText="Rechercher par nom, prénom, email..."
                           styleClass="search-field"
                           style="-fx-pref-width: 340px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="countLabel"
                       style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
            </HBox>

            <Separator/>

            <!-- TableView -->
            <TableView fx:id="tableView" styleClass="table-view"
                       style="-fx-border-width: 0; -fx-background-radius: 0;"
                       VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNum"       text="N°"          prefWidth="65"  minWidth="55"/>
                    <TableColumn fx:id="colNom"       text="Nom Complet" prefWidth="220" minWidth="160"/>
                    <TableColumn fx:id="colEmail"     text="Email"       prefWidth="200" minWidth="140"/>
                    <TableColumn fx:id="colSexe"      text="Sexe"        prefWidth="70"  minWidth="60"/>
                    <TableColumn fx:id="colDateNaiss" text="Date Naiss." prefWidth="110" minWidth="90"/>
                    <TableColumn fx:id="colCompte"    text="N° Compte"   prefWidth="150" minWidth="120"/>
                </columns>
                <placeholder>
                    <Label text="Aucun patient trouvé"
                           style="-fx-text-fill: #94A3B8; -fx-font-size: 14px; -fx-padding: 40;"/>
                </placeholder>
            </TableView>

            <!-- Pagination -->
            <HBox alignment="CENTER" spacing="12">
                <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
                <Button fx:id="btnPrevPage" text="◀ Précédent"
                        styleClass="btn-secondary" onAction="#handlePrevPage"
                        style="-fx-pref-height: 36px; -fx-font-size: 12px;"/>
                <Label fx:id="pageInfoLabel"
                       style="-fx-font-size: 13px; -fx-text-fill: #64748B; -fx-min-width: 120px; -fx-alignment: CENTER;"/>
                <Button fx:id="btnNextPage" text="Suivant ▶"
                        styleClass="btn-secondary" onAction="#handleNextPage"
                        style="-fx-pref-height: 36px; -fx-font-size: 12px;"/>
            </HBox>

        </VBox>
    </VBox>
</ScrollPane>
