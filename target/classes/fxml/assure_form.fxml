<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox styleClass="modal-card" maxWidth="600" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.securitesociale.controller.AssureFormController">

    <HBox styleClass="modal-header" alignment="CENTER_LEFT">
        <StackPane styleClass="modal-header-icon">
            <FontIcon iconLiteral="fas-user-plus" iconSize="22" styleClass="modal-header-fa-icon"/>
        </StackPane>
        <VBox styleClass="modal-header-text">
            <Label text="Nouvel Assuré" styleClass="modal-header-title"/>
            <Label text="Remplissez les informations du nouvel assuré" styleClass="modal-header-subtitle"/>
        </VBox>
    </HBox>

    <VBox styleClass="modal-body" minWidth="520" spacing="16">
        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Nom *" styleClass="field-label"/>
                <TextField fx:id="nomField" promptText="Nom de famille"
                           styleClass="text-field-modern" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Prénom *" styleClass="field-label"/>
                <TextField fx:id="prenomField" promptText="Prénom"
                           styleClass="text-field-modern" maxWidth="Infinity"/>
            </VBox>
        </HBox>

        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Date de naissance" styleClass="field-label"/>
                <DatePicker fx:id="dateNaissancePicker" promptText="jj/mm/aaaa"
                            styleClass="date-picker-modern" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Sexe" styleClass="field-label"/>
                <ComboBox fx:id="sexeCombo" promptText="Sélectionner..."
                          styleClass="combo-box-modern" maxWidth="Infinity"/>
            </VBox>
        </HBox>

        <VBox spacing="6">
            <Label text="Email" styleClass="field-label"/>
            <TextField fx:id="emailField" promptText="email@exemple.com"
                       styleClass="text-field-modern"/>
        </VBox>

        <VBox spacing="6">
            <Label text="N° Compte Bancaire" styleClass="field-label"/>
            <TextField fx:id="numCompteField" promptText="Ex : FR76 XXXX XXXX..."
                       styleClass="text-field-modern"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Médecin Traitant" styleClass="field-label"/>
            <ComboBox fx:id="medecinCombo" promptText="Sélectionner un médecin..."
                      styleClass="combo-box-modern" maxWidth="Infinity"/>
        </VBox>

        <Label fx:id="errorLabel" text="" styleClass="error-label"
               visible="false" managed="false" wrapText="true"/>
    </VBox>

    <HBox styleClass="modal-footer">
        <Button text="Annuler" styleClass="btn-secondary" onAction="#handleCancel"/>
        <Button fx:id="saveBtn" text="✔ Enregistrer l'assuré"
                styleClass="btn-primary" onAction="#handleSave"/>
    </HBox>

</VBox>
